  ('pc-sinker',          'PC Sinker',          'Poly-cotton sinker with balanced weight and dimensional stability.',                                'Sinker Knit',  ARRAY['Lowers'], true, 13),
  ('pc-matty',           'PC Matty',           'Poly-cotton matty weave — structured surface with breathability for lowers and trackwear.',         'Matty Weave',  ARRAY['Lowers'], true, 14),
  ('airjet-loop-knit',   'Airjet Loop Knit',   'Airjet-spun loop knit with refined hand and consistent loop structure.',                            'Loop Knit',    ARRAY['Lowers','Joggers'], true, 15),
  ('swead-lycra',        'Swead Lycra',        'Lycra-blended fabric with sweat-management properties for active lowers.',                          'Lycra Knit',   ARRAY['Lowers'], true, 16),
