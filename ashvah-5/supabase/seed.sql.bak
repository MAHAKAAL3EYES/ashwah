  ('spandex-rib',        'Spandex Rib',        'Ribbed spandex with high vertical recovery — used for structured lowers and rib detailing.',        'Rib Knit',     ARRAY['Lowers'], true, 18),
  ('nylon-terry',        'Nylon Terry',        'Nylon-based terry construction — moisture-managing and abrasion-resistant.',                       'Terry Knit',   ARRAY['Lowers'], true, 19),
  ('n-s-lycra-p',        'N S Lycra (P)',      'NS lycra blend with premium finish — engineered for lowers and athleisure.',                       'Lycra Knit',   ARRAY['Lowers'], true, 20),
